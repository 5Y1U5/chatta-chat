generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

// === ユーザー（Supabase Auth と 1:1）===
model User {
  id              String   @id @default(uuid())
  supabaseUserId  String   @unique
  email           String
  displayName     String?
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceMembers WorkspaceMember[]
  channelMembers   ChannelMember[]
  messages         Message[]
  reactions        Reaction[]
}

// === ワークスペース（組織/チーム単位）===
model Workspace {
  id        String   @id @default(uuid())
  name      String
  iconUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  WorkspaceMember[]
  channels Channel[]
}

// === ワークスペースメンバー ===
model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member") // admin | member
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// === チャンネル ===
model Channel {
  id          String   @id @default(uuid())
  workspaceId String
  name        String?  // DM の場合は null
  type        String   @default("public") // public | group | dm
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   ChannelMember[]
  messages  Message[]
}

// === チャンネルメンバー ===
model ChannelMember {
  id         String    @id @default(uuid())
  channelId  String
  userId     String
  lastReadAt DateTime? // 最後にチャンネルを閲覧した日時（未読計算用）
  createdAt  DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

// === メッセージ ===
model Message {
  id          String   @id @default(uuid())
  channelId   String
  userId      String
  content     String
  parentId    String?  // スレッド返信の親メッセージID
  aiGenerated Boolean  @default(false) // AI 生成メッセージフラグ
  fileUrl     String?  // 添付ファイルの URL
  fileName    String?  // 添付ファイル名
  fileType    String?  // MIME タイプ（image/png 等）
  deletedAt   DateTime? // ソフトデリート（null = 有効）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Message?   @relation("ThreadReplies", fields: [parentId], references: [id])
  replies   Message[]  @relation("ThreadReplies")
  reactions Reaction[]

  @@index([channelId, createdAt])
}

// === リアクション ===
model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}
