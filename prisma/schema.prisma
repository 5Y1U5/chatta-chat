generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

// === ユーザー（Supabase Auth と 1:1）===
model User {
  id              String   @id @default(uuid())
  supabaseUserId  String   @unique
  email           String
  displayName     String?
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceMembers WorkspaceMember[]
  channelMembers   ChannelMember[]
  messages         Message[]
  reactions        Reaction[]
  assignedTasks    Task[]          @relation("TaskAssignee")
  createdTasks     Task[]          @relation("TaskCreator")
  taskComments     TaskComment[]
  projectMembers   ProjectMember[]
  taskMembers      TaskMember[]
  notifications    Notification[]  @relation("NotificationRecipient")
  actedNotifications Notification[] @relation("NotificationActor")
  taskShareLinks   TaskShareLink[] @relation("TaskShareLinkCreator")
}

// === ワークスペース（組織/チーム単位）===
model Workspace {
  id         String   @id @default(uuid())
  name       String
  iconUrl    String?
  inviteCode String?  @unique // ワークスペース招待コード
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members  WorkspaceMember[]
  channels Channel[]
  projects Project[]
  tasks    Task[]
}

// === ワークスペースメンバー ===
model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("member") // admin | member
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// === チャンネル ===
model Channel {
  id          String   @id @default(uuid())
  workspaceId String
  name        String?  // DM の場合は null
  type        String   @default("public") // public | group | dm
  inviteCode  String?  @unique // チャンネル招待コード
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   ChannelMember[]
  messages  Message[]
  memories  ChannelMemory[]
}

// === チャンネルメンバー ===
model ChannelMember {
  id         String    @id @default(uuid())
  channelId  String
  userId     String
  lastReadAt DateTime? // 最後にチャンネルを閲覧した日時（未読計算用）
  createdAt  DateTime  @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

// === メッセージ ===
model Message {
  id          String   @id @default(uuid())
  channelId   String
  userId      String
  content     String
  parentId    String?  // スレッド返信の親メッセージID
  aiGenerated Boolean  @default(false) // AI 生成メッセージフラグ
  fileUrl     String?  // 添付ファイルの URL
  fileName    String?  // 添付ファイル名
  fileType    String?  // MIME タイプ（image/png 等）
  deletedAt   DateTime? // ソフトデリート（null = 有効）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Message?   @relation("ThreadReplies", fields: [parentId], references: [id])
  replies   Message[]  @relation("ThreadReplies")
  reactions Reaction[]

  @@index([channelId, createdAt])
}

// === リアクション ===
model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// === チャンネル重要事項メモリ ===
model ChannelMemory {
  id              String   @id @default(uuid())
  channelId       String
  content         String   // 検出された重要事項
  category        String   // decision | deadline | action | info
  sourceMessageId String?  // 検出元メッセージID
  detectedAt      DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, detectedAt])
}

// === プロジェクト ===
model Project {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  description String?
  color       String?  // UI での識別色（例: "#3B82F6"）
  inviteCode  String?  @unique // プロジェクト招待コード（12文字）
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]
  members   ProjectMember[]

  @@index([workspaceId])
}

// === プロジェクトメンバー ===
model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member") // owner | member
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

// === タスク ===
model Task {
  id             String    @id @default(uuid())
  workspaceId    String
  projectId      String?   // 所属プロジェクト（任意）
  parentTaskId   String?   // サブタスクの親
  title          String
  description    String?   // 説明欄
  status         String    @default("todo") // todo | in_progress | done
  priority       String    @default("medium") // high | medium | low
  assigneeId     String?   // 担当者
  creatorId      String    // 作成者
  dueDate        DateTime? // 期日
  completedAt    DateTime? // 完了日時
  recurrenceRule String?   // RFC 5545 RRULE 形式（例: "FREQ=WEEKLY;BYDAY=MO"）
  nextOccurrence DateTime? // 次回繰り返し発生日
  sortOrder      Int       @default(0) // 手動並び替え用（小さいほど上）
  fileUrl        String?   // 添付ファイルの URL
  fileName       String?   // 添付ファイル名
  fileType       String?   // MIME タイプ
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee   User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator    User          @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  parentTask Task?         @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks   Task[]        @relation("SubTasks")
  comments      TaskComment[]
  members       TaskMember[]
  shareLinks    TaskShareLink[]
  guestComments GuestComment[]

  @@index([workspaceId, assigneeId, status])
  @@index([projectId, status])
  @@index([parentTaskId])
}

// === タスクメンバー（招待されたコラボレーター）===
model TaskMember {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

// === タスク内チャット ===
model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  fileUrl   String?
  fileName  String?
  fileType  String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

// === 通知（受信トレイ）===
model Notification {
  id        String   @id @default(uuid())
  userId    String   // 通知の宛先
  type      String   // task_completed | task_comment | task_assigned
  title     String   // 表示テキスト
  taskId    String?
  projectId String?
  actorId   String   // アクションを起こしたユーザー
  read      Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// === タスク共有リンク（ゲストアクセス用）===
model TaskShareLink {
  id        String    @id @default(uuid())
  taskId    String
  token     String    @unique  // 32文字 hex（推測不可能）
  createdBy String               // リンク生成者
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  expiresAt DateTime?            // v1は無期限

  task    Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  creator User @relation("TaskShareLinkCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  guestComments GuestComment[]

  @@index([taskId])
}

// === ゲストコメント（未登録ユーザー）===
model GuestComment {
  id          String   @id @default(uuid())
  taskId      String
  shareLinkId String
  guestName   String
  content     String
  createdAt   DateTime @default(now())

  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  shareLink TaskShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}
